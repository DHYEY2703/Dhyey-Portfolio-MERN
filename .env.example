# === Production Deployment Config === #

# The actual public URL that your backend runs on (so the frontend container can talk to it)
VITE_API_URL=https://api.your-live-domain.com

# Backend Secrets
JWT_SECRET=INSERT_YOUR_SECURE_JWT_SECRET_HERE
ADMIN_PASSWORD=INSERT_A_STRONG_PASSWORD_HERE

# Database
MONGO_URI=mongodb://mongo:27017/portfolio
